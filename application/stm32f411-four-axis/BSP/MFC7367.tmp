//前后速度增量PI
//输入参数：期望速度，实际速度
//输出参数：期望角度
float Direct_X_SPcurb(float Ek_Speed, float Now_Speed)
{
	static float pwm_Direct_X_SP, Last_Direct_X_SP_error; 		//增量式的速度都是基于上一次总的速度做出的改变
	float Direct_X_SP_error;

	Direct_X_SP_error = Ek_Speed - Now_Speed;
	
	pwm_Direct_X_SP += Alt_SP_Kp*(Direct_X_SP_error - Last_Direct_X_SP_error) 
						+ Alt_SP_Ki*Direct_X_SP_error;
	
	//限幅
  pwm_Direct_X_SP = pwm_Direct_X_SP > 10 ? 10 : (pwm_Direct_X_SP < -10 ? -10 : pwm_Direct_X_SP);          //限幅是按实际轮上扭矩期望来限的
	
	Last_Direct_X_SP_error = Direct_X_SP_error;
	
	return Direct_X_SP_error;
}


//左右速度增量PI
//输入参数：期望速度，实际速度
//输出参数：期望角度
float Direct_Y_SPcurb(float Ek_Speed, float Now_Speed)
{
	static float pwm_Direct_Y_SP, Last_Direct_Y_SP_error; 		//增量式的速度都是基于上一次总的速度做出的改变
	float Direct_Y_SP_error;

	Direct_Y_SP_error = Ek_Speed - Now_Speed;
	
	pwm_Direct_Y_SP += Alt_SP_Kp*(Direct_Y_SP_error - Last_Direct_Y_SP_error) 
						+ Alt_SP_Ki*Direct_Y_SP_error;
	
	//限幅
  pwm_Direct_Y_SP = pwm_Direct_Y_SP > 10 ? 10 : (pwm_Direct_Y_SP < -10 ? -10 : pwm_Direct_Y_SP);          //限幅是按实际轮上扭矩期望来限的
	
	Last_Direct_Y_SP_error = Direct_Y_SP_error;
	
	return Direct_Y_SP_error;
}

